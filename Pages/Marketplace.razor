@page "/marketplace"

@inject NavigationManager Navigation
@inject ILogger<Marketplace> Logger
@inject IGameService GameService
@inject ICollectionService CollectionService
@inject AuthenticationStateProvider AuthStateProvider

@using GameStoreWeb.Services
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.Web

@using GameStoreWeb.DTOs
@* @using GameStoreWeb.Models *@
@using GameStoreWeb.Components
@using System.Security.Claims

<AuthorizeView>
    <Authorized>

        <div class="max-w-7xl mx-auto px-6 py-8">

            <div class="flex items-center justify-between mb-8">

                <h2 class="text-3xl font-bold">Marketplace</h2>

                <ButtonComponentBlazor Type="button" Value="➕ Add Game" OnClickUrlString="/addGame" BgColor="48A6A7"
                    OnMouseEnterBgColor="006A71" />

            </div>

            <div class="mb-6">

                <input type="text" placeholder="Search games..." @bind="SearchText" @bind:event="oninput"
                    class="w-full max-w-md px-4 py-2 rounded-lg border border-gray-600 bg-gray-800 text-white" />

            </div>

            @if (games == null)
            {
                <div class="text-gray-400 text-lg animate-pulse">
                    Loading games...
                </div>
            }
            else if (games.Count == 0)
            {
                <p>No games found.</p>
            }
            else
            {
                <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">

                    @foreach (var game in FilteredGames)
                    {
                        Models.GameReadDto sendGame = new Models.GameReadDto
                        {
                            Id = game.Id,
                            Title = game.Title,
                            Description = game.Description,
                            GameUrl = game.GameUrl,
                            ThumbnailUrl = game.ThumbnailUrl,
                            AuthorUserId = game.AuthorUserId,
                            CreatedAt = game.CreatedAt
                        };
                        <GameTile Game="sendGame" IsInCollection="false" AllowEditing="allowEdit" OnEditClicked="EditGame" />
                    }

                </div>
            }

        </div>

    </Authorized>
    <NotAuthorized>
        <p>You must <a href="/Account/Login">log in</a>.</p>
    </NotAuthorized>
</AuthorizeView>

@code {
    private List<GameReadDto> games = new();
    private List<GameReadDto> savedGames = new();
    private bool allowEdit = false;

    private string SearchText = "";
    private IEnumerable<GameReadDto> FilteredGames =>
    string.IsNullOrWhiteSpace(SearchText)
    ? games
    : games.Where(g =>
    g.Title.Contains(SearchText, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user?.Identity == null || !user.Identity.IsAuthenticated)
        {
            return; // UI will handle NotAuthorized
        }

        var userIdClaim = user.FindFirst(ClaimTypes.NameIdentifier);
        if (userIdClaim == null)
        {
            return;
        }

        var userId = Guid.Parse(userIdClaim.Value);
        try
        {
            games = (await GameService.GetAllAsync()).ToList();
            savedGames = (await CollectionService.GetUserCollectionAsync(userId)).ToList();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading games.");
        }
    }
    private void Navigate()
    {
        Navigation.NavigateTo("/addGame");
    }

    private void EditGame(Guid gameId)
    {
        Navigation.NavigateTo($"/mygames/edit/{gameId}");
    }
}