@page "/analytics/playtime"

@inject IHttpClientFactory HttpClientFactory
@using Microsoft.JSInterop;
@inject IJSRuntime JS
@using GameStoreWeb.Services
@using GameStoreWeb.DTOs
@inject IStatisticsService StatisticsService

<h2>Total Playtime Per Game</h2>

<div class="bg-gray-900 p-6 rounded-xl border border-fuchsia-500/20 shadow-lg">
    <h3 class="text-lg text-white mb-4">Trending Games</h3>
    <canvas id="playtimeChart" width="400" height="200"></canvas>
</div>

@code {

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        List<GamePlaytimeDto> data;
        if (!firstRender) return;

        @* var client = HttpClientFactory.CreateClient("GameStoreApiService"); *@

        @* var data = await client.GetFromJsonAsync<List<GamePlaytimeDto>>(
        "api/statistics/total-playtime"); *@
        data = await StatisticsService.GetTotalPlaytimePerGameAsync();
        var labels = data.Select(g => g.Title).ToArray();
        var minutes = data.Select(g => g.TotalMinutes).ToArray();

        await JS.InvokeVoidAsync("renderPlaytimeChart", labels, minutes);
    }
}