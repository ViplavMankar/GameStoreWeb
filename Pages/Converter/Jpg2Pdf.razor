@page "/converter/jpg-to-pdf"
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Components.Web
@inject IHttpClientFactory HttpClientFactory
@using GameStoreWeb.Services
@inject IS3Service S3Service

<h3>JPG to PDF Converter</h3>

<div class="upload-container">
    <InputFile OnChange="HandleFileSelected" accept=".jpg,.jpeg" />

    @if (imagePreview != null)
    {
        <div class="preview-section">
            <h5>Preview:</h5>
            <img src="@imagePreview" class="preview-image" />
        </div>
    }

    @if (imagePreview != null && !isUploading)
    {
        <button class="btn btn-primary" @onclick="UploadAndConvert">
            Convert to PDF
        </button>
    }

    @if (isUploading)
    {
        <p>Converting...</p>
    }

    @if (downloadUrl != null)
    {
        <a href="@downloadUrl" download="converted.pdf" class="btn btn-success">
            Download PDF
        </a>
    }
</div>

@code {
    private IBrowserFile? selectedFile;
    private string? imagePreview;
    private string? downloadUrl;
    private bool isUploading = false;

    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        downloadUrl = null;

        selectedFile = e.File;

        // ❌ Restrict size (5MB)
        if (selectedFile.Size > 5 * 1024 * 1024)
        {
            imagePreview = null;
            return;
        }

        // ✅ Generate preview
        using var stream = selectedFile.OpenReadStream(5 * 1024 * 1024);
        using var ms = new MemoryStream();
        await stream.CopyToAsync(ms);

        var base64 = Convert.ToBase64String(ms.ToArray());
        imagePreview = $"data:{selectedFile.ContentType};base64,{base64}";
    }

    private async Task UploadAndConvert()
    {
        if (selectedFile == null)
            return;

        isUploading = true;

        @* using var content = new MultipartFormDataContent(); *@
        using var fileStream = selectedFile.OpenReadStream(10 * 1024 * 1024);
        byte[] imageBytes;
        using (var ms = new MemoryStream())
        {
            await fileStream.CopyToAsync(ms);
            imageBytes = ms.ToArray();
        }
        @* using var streamContent = new StreamContent(fileStream); *@

        @* streamContent.Headers.ContentType =
        new System.Net.Http.Headers.MediaTypeHeaderValue(selectedFile.ContentType); *@

        @* content.Add(streamContent, "file", selectedFile.Name);
        var http = HttpClientFactory.CreateClient("GameStoreApiService"); *@

        @* var response = await http.PostAsync("api/files/jpg-to-pdf", content); *@
        var pdfBytes = S3Service.ConvertSingleImageToPdf(imageBytes);

        if (pdfBytes == null)
        {
            Console.WriteLine("Conversion failed");
            isUploading = false;
            return;
        }
        else
        {
            downloadUrl = $"data:application/pdf;base64,{Convert.ToBase64String(pdfBytes)}";
        }

        isUploading = false;
    }
}